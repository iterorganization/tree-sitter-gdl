# PyPI API token for publishing releases
# Get this from https://pypi.org/manage/account/token/
# Set as PYPI_API_TOKEN secret in GitHub repository settings
# PYPI_API_TOKEN=pypi-...

# Note: The release workflow uses PyPI trusted publishers (OIDC),
# so no API token is needed in .env for CI/CD.
# The .env file is for local development reference only.

# Local development:
#   uv pip install -e .          # install in development mode
#   uv run pytest tests/ -v     # run tests
#   uv build                    # build sdist + wheel
#
# Versioning:
#   Version is derived from git tags via setuptools-scm.
#   Tag format: v0.1.0 → version 0.1.0
#   Without a tag, version is e.g. 0.1.0.dev4+g1234567
#
# Release:
#   git tag v0.1.0
#   git push upstream v0.1.0    # triggers release workflow
